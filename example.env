RP_RIPPLE1D_API_URL=http://127.0.0.1
RP_STAC_URL=models_catalog_stac_url

# Provide empty string or omit for direct access
RP_STAC_AWS_ACCESS_KEY_ID=your_access_key_id
RP_STAC_AWS_SECRET_ACCESS_KEY=your_secret_access_key
RP_STAC_AWS_REGION=us-east-1

# Optional: prefix for s3 key, useful for testing with a different bucket or prefix.
#RP_S3_KEY_PREFIX=fimc-data/

# Pipeline log level: DEBUG, INFO, WARNING, ERROR
RP_LOG_LEVEL=INFO

# Log floor for third-party libraries
RP_THIRD_PARTY_LOG_LEVEL=WARNING

# --- Machine / environment config ---
RP_RIPPLE1D_VERSION=0.10.4

# Filesystem paths (edit for your machine)
RP_COLLECTIONS_ROOT_DIR=C:\path\to\collections
RP_NWM_FLOWLINES_PATH=C:\reference_data\nwm_flowlines.parquet
RP_MONITORING_DB_PATH=C:\path\to\monitoring.sqlite
RP_BRIDGE_TILE_INDEX_PATH=/vsis3/fimc-data/reference/owp_bridge_data/bridge_index.parquet
RP_TERRAIN_SOURCE_URL=C:\reference_data\dem\seamless_3dep_dem_3m_5070.vrt
RP_SOURCE_NETWORK=C:\reference_data\nwm_flowlines_with_bbox.parquet
RP_FLOW_FILES_DIR=C:\reference_data\flow_files

# flows2fim + GDAL binaries
RP_FLOWS2FIM_BIN_PATH=C:\OSGeo4W\bin\flows2fim.exe
RP_GDAL_BINS_PATH=C:\OSGeo4W\bin
RP_GDAL_SCRIPTS_PATH=C:\OSGeo4W\apps\Python312\Scripts

# QC template
RP_QC_TEMPLATE_QGIS_FILE=C:\reference_data\qc_map.qgs

# Parallel worker count (rule of thumb - half the cores available)
RP_OPTIMUM_PARALLEL_PROCESS_COUNT=22

# S3 upload destinations (exclude trailing slash; leave blank to skip)
RP_S3_UPLOAD_PREFIX=
RP_S3_UPLOAD_FAILED_PREFIX=


